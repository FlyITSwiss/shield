{
  "name": "shield-app",
  "version": "1.0.0",
  "description": "SHIELD - Application mobile de securite feminine",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run watch:css\" \"npm run watch:js\"",
    "watch:css": "sass --watch public/assets/css:public/assets/css",
    "watch:js": "esbuild public/assets/js/app.js --bundle --outfile=public/assets/js/bundle.js --watch",
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass public/assets/css/shield-core.scss:public/assets/css/shield-core.min.css --style=compressed",
    "build:js": "esbuild public/assets/js/app.js --bundle --outfile=public/assets/js/bundle.min.js --minify",
    "test": "npx playwright test --headed",
    "test:headless": "npx playwright test",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "lint": "eslint public/assets/js/**/*.js",
    "lint:fix": "eslint public/assets/js/**/*.js --fix",
    "phpstan": "docker exec shield-app-local sh -c \"cd /var/www/shield && vendor/bin/phpstan analyse --configuration=phpstan.neon\"",
    "i18n:validate": "node scripts/i18n-validator.js",
    "validate": "node scripts/validators/run-all.js",
    "validate:staged": "node scripts/validators/run-all.js --staged",
    "validate:strict": "node scripts/validators/run-all.js --strict",
    "smoke": "npx playwright test tests/playwright/smoke-auth.spec.ts tests/playwright/smoke-app.spec.ts tests/playwright/smoke-critical.spec.ts --headed",
    "smoke:headless": "npx playwright test tests/playwright/smoke-auth.spec.ts tests/playwright/smoke-app.spec.ts tests/playwright/smoke-critical.spec.ts",
    "smoke:critical": "npx playwright test tests/playwright/smoke-critical.spec.ts --headed",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:build:android": "cd android && ./gradlew assembleDebug",
    "cap:build:android:release": "cd android && ./gradlew assembleRelease",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "docker:rebuild": "docker-compose -f docker/docker-compose.yml up -d --build",
    "deploy": "gh workflow run deploy-vps.yml",
    "deploy:full": "gh workflow run deploy-complet.yml",
    "deploy:fallback": "bash scripts/deploy-fallback.sh",
    "deploy:fallback:skip-migrations": "bash scripts/deploy-fallback.sh --skip-migrations",
    "deploy:rollback": "bash scripts/deploy-fallback.sh --rollback",
    "postdeploy:check": "npm run smoke:critical -- --reporter=list",
    "postdeploy:health": "curl -sI https://stabilis-it.ch/internal/shield/health | head -1",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit",
    "hooks:check": "git config --get core.hooksPath"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "alpinejs": "^3.14.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "sass": "^1.80.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": [
    "iOS >= 14",
    "Android >= 8",
    "Chrome >= 90",
    "Firefox >= 90",
    "Safari >= 14"
  ],
  "author": "Stabilis IT",
  "license": "UNLICENSED"
}

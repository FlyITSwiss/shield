<?php
/**
 * SHIELD - Live Location Sharing (Premium Feature)
 *
 * Permet de partager sa position en temps reel avec des contacts de confiance
 * Mode "Je rentre" avec destination et ETA
 */
$pageTitle = __('share.title') ?? 'Partage de position';
$bodyClass = 'page-location-share';
$showNavigation = true;
$currentPage = 'share';
$pageScripts = ['app/location-share.js'];

// Recuperer les contacts de confiance
$contacts = [];
try {
    require_once MODELS_PATH . '/Contact.php';
    $contactModel = new \Shield\Models\Contact(get_db());
    $contacts = $contactModel->getByUser((int)$_SESSION['user_id']);
} catch (Exception $e) {
    error_log('Failed to load contacts: ' . $e->getMessage());
}

// Recuperer les partages actifs
$activeShares = [];
try {
    require_once SERVICES_PATH . '/LocationShareService.php';
    $shareService = new \Shield\Services\LocationShareService(get_db());
    $activeShares = $shareService->getActiveByUser((int)$_SESSION['user_id']);
} catch (Exception $e) {
    error_log('Failed to load shares: ' . $e->getMessage());
}

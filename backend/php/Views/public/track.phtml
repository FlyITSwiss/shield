<script>
function trackingPage(shareId) {
    return {
        shareId: shareId,
        loading: true,
        error: false,
        errorMessage: '',
        incident: {},
        location: {},
        contacts: [],
        myContactId: null,
        responding: false,
        pollInterval: null,
        map: null,
        marker: null,

        // Computed
        get hasAcknowledged() {
            if (!this.myContactId) return false;
            const me = this.contacts.find(c => c.contact_id === this.myContactId);
            return me && ['acknowledged', 'responding', 'arrived'].includes(me.status);
        },

        get isResponding() {
            if (!this.myContactId) return false;
            const me = this.contacts.find(c => c.contact_id === this.myContactId);
            return me && ['responding', 'arrived'].includes(me.status);
        },

        get hasArrived() {
            if (!this.myContactId) return false;
            const me = this.contacts.find(c => c.contact_id === this.myContactId);
            return me && me.status === 'arrived';
        },

        get canRespond() {
            return this.myContactId !== null;
        },

        async init() {
            await this.fetchData();

            if (!this.error) {
                this.initMap();
                this.startPolling();
            }
        },

        async fetchData() {
            try {
                const response = await fetch(`/api/track.php?share_id=${this.shareId}`);
                const data = await response.json();

                if (!data.success) {
                    this.error = true;
                    this.errorMessage = data.error === 'expired' ?
                        '<?= __('error.link_expired') ?>' :
                        '<?= __('error.tracking_unavailable') ?>';
                    return;
                }

                this.incident = data.incident || {};
                this.location = data.location || {};
                this.contacts = data.contacts || [];
                this.myContactId = data.my_contact_id || null;

                // Update map if exists
                if (this.map && this.location.latitude) {
                    this.updateMapPosition();
                }

            } catch (e) {
                console.error('Fetch error:', e);
                this.error = true;
                this.errorMessage = '<?= __('error.network') ?>';
            } finally {
                this.loading = false;
            }
        },

        initMap() {
            if (!this.location.latitude || !this.location.longitude) return;

            // Use Leaflet for map
            if (typeof L !== 'undefined') {
                this.map = L.map('tracking-map').setView(
                    [this.location.latitude, this.location.longitude],
                    15
                );

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(this.map);

                this.marker = L.marker([this.location.latitude, this.location.longitude])
                    .addTo(this.map)
                    .bindPopup('<?= __('sos.person_location') ?>')
                    .openPopup();
            }
        },

        updateMapPosition() {
            if (!this.map || !this.marker) return;
            if (!this.location.latitude || !this.location.longitude) return;

            const latlng = [this.location.latitude, this.location.longitude];
            this.marker.setLatLng(latlng);
            this.map.panTo(latlng);
        },

        startPolling() {
            this.pollInterval = setInterval(() => {
                this.fetchData();
            }, 10000); // Poll every 10 seconds
        },

        stopPolling() {
            if (this.pollInterval) {
                clearInterval(this.pollInterval);
            }
        },

        async acknowledge() {
            if (!this.myContactId) return;
            this.responding = true;

            try {
                const response = await fetch('/api/incidents.php?action=acknowledge-contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        incident_id: this.incident.uuid,
                        contact_id: this.myContactId
                    })
                });

                await this.fetchData();
            } catch (e) {
                console.error('Acknowledge error:', e);
            } finally {
                this.responding = false;
            }
        },

        async markResponding() {
            if (!this.myContactId) return;

            try {
                await fetch('/api/incidents.php?action=contact-responding', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        incident_id: this.incident.uuid,
                        contact_id: this.myContactId
                    })
                });

                await this.fetchData();
            } catch (e) {
                console.error('Responding error:', e);
            }
        },

        async markArrived() {
            if (!this.myContactId) return;

            try {
                await fetch('/api/incidents.php?action=contact-arrived', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        incident_id: this.incident.uuid,
                        contact_id: this.myContactId
                    })
                });

                await this.fetchData();
            } catch (e) {
                console.error('Arrived error:', e);
            }
        },

        // Helpers
        getStatusLabel(status) {
            const labels = {
                'active': '<?= __('sos.status_active') ?>',
                'resolved': '<?= __('sos.status_resolved') ?>',
                'cancelled': '<?= __('sos.status_cancelled') ?>',
                'false_alarm': '<?= __('sos.status_false_alarm') ?>'
            };
            return labels[status] || status;
        },

        getTriggerLabel(method) {
            const labels = {
                'five_taps': '<?= __('sos.trigger_five_taps') ?>',
                'volume_hold': '<?= __('sos.trigger_volume') ?>',
                'voice_command': '<?= __('sos.trigger_voice') ?>',
                'button': '<?= __('sos.trigger_button') ?>'
            };
            return labels[method] || method;
        },

        getContactStatusLabel(status) {
            const labels = {
                'pending': '<?= __('contacts.status.pending') ?>',
                'notified': '<?= __('contacts.status.sending') ?>',
                'delivered': '<?= __('contacts.status.delivered') ?>',
                'acknowledged': '<?= __('contacts.status.acknowledged') ?>',
                'responding': '<?= __('contacts.status.responding') ?>',
                'arrived': '<?= __('contacts.status.arrived') ?>'
            };
            return labels[status] || status;
        },

        formatTime(timestamp) {
            if (!timestamp) return '--:--';
            const date = new Date(timestamp);
            return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
        },

        formatDuration(startedAt) {
            if (!startedAt) return '00:00';
            const start = new Date(startedAt);
            const now = new Date();
            const diff = Math.floor((now - start) / 1000);
            const mins = Math.floor(diff / 60);
            const secs = diff % 60;
            return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        },

        destroy() {
            this.stopPolling();
            if (this.map) {
                this.map.remove();
            }
        }
    };
}
</script>


<script>
(function() {
    const data = window.ShieldShareData;
    let map, marker, destinationMarker;
    let updateInterval;

    function initMap() {
        if (!data.latitude || !data.longitude) {
            document.getElementById('share-map').innerHTML = '<div class="map-placeholder">En attente de la position...</div>';
            return;
        }

        map = L.map('share-map').setView([data.latitude, data.longitude], 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: ''
        }).addTo(map);

        // User marker with pulse effect
        const pulseIcon = L.divIcon({
            className: 'pulse-marker',
            html: '<div class="pulse-ring"></div><div class="pulse-core"></div>',
            iconSize: [40, 40],
            iconAnchor: [20, 20]
        });

        marker = L.marker([data.latitude, data.longitude], { icon: pulseIcon }).addTo(map);

        // Destination marker if journey mode
        if (data.share_type === 'journey' && data.destination_lat && data.destination_lng) {
            destinationMarker = L.marker([data.destination_lat, data.destination_lng], {
                icon: L.divIcon({
                    className: 'destination-marker',
                    html: '<div class="destination-pin">D</div>',
                    iconSize: [30, 40],
                    iconAnchor: [15, 40]
                })
            }).addTo(map);

            // Draw route line
            L.polyline([
                [data.latitude, data.longitude],
                [data.destination_lat, data.destination_lng]
            ], {
                color: '#8E24AA',
                weight: 3,
                opacity: 0.7,
                dashArray: '10, 10'
            }).addTo(map);

            // Fit bounds
            map.fitBounds([
                [data.latitude, data.longitude],
                [data.destination_lat, data.destination_lng]
            ], { padding: [50, 50] });
        }
    }

    async function fetchUpdates() {
        if (data.status !== 'active') return;

        try {
            const basePath = window.location.pathname.includes('/internal/shield')
                ? '/internal/shield'
                : '';
            const response = await fetch(`${basePath}/api/location-share.php?action=view&token=${data.token}`);
            const result = await response.json();

            if (result.success && result.share) {
                updateUI(result.share);
            }
        } catch (error) {
            console.error('Update failed:', error);
        }
    }

    function updateUI(share) {
        // Update marker position
        if (map && marker && share.last_latitude && share.last_longitude) {
            marker.setLatLng([share.last_latitude, share.last_longitude]);
            map.panTo([share.last_latitude, share.last_longitude]);
        }

        // Update time
        const timeEl = document.getElementById('last-update-time');
        if (timeEl && share.last_location_at) {
            timeEl.textContent = new Date(share.last_location_at).toLocaleTimeString('fr-FR', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
        }

        // Update address
        const addressEl = document.getElementById('current-address');
        if (addressEl && share.last_address) {
            addressEl.textContent = share.last_address;
        }

        // Update battery
        const batteryEl = document.getElementById('battery-level');
        if (batteryEl && share.battery_level) {
            batteryEl.textContent = share.battery_level;
        }

        // Update speed
        const speedEl = document.getElementById('current-speed');
        if (speedEl && share.last_speed) {
            speedEl.textContent = Math.round(share.last_speed);
        }

        // Check status change
        if (share.status !== data.status) {
            window.location.reload();
        }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
        initMap();

        // Poll for updates every 10 seconds
        if (data.status === 'active') {
            updateInterval = setInterval(fetchUpdates, 10000);
        }
    });

    // Cleanup
    window.addEventListener('beforeunload', () => {
        if (updateInterval) clearInterval(updateInterval);
    });
})();
</script>


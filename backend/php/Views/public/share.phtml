        'destination_lat' => $share['destination_latitude'] ? (float)$share['destination_latitude'] : null,
        'destination_lng' => $share['destination_longitude'] ? (float)$share['destination_longitude'] : null,
        'status' => $share['status'],
        'share_type' => $share['share_type']
    ]) ?>;

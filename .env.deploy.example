# SHIELD - Configuration Déploiement VPS
# Copier en .env.deploy et remplir les valeurs

# ============================================
# APPLICATION
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://stabilis-it.ch/internal/shield

# ============================================
# DATABASE (MySQL sur VPS)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=shield_prod
DB_USERNAME=shield_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# SESSION & SECURITY
# ============================================
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_STRING
SESSION_LIFETIME=86400

# ============================================
# API KEYS (Services externes)
# ============================================
# Twilio (SMS/Appels)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=

# OpenAI (Agent IA)
OPENAI_API_KEY=

# Firebase (Push notifications)
FIREBASE_SERVER_KEY=

# ============================================
# REDIS (optionnel, pour cache/sessions)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# TESTING (pour désactiver temporairement les protections)
# ============================================
TEST_TOKEN=shield-test-token-change-in-production

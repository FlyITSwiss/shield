    local violations=0

    if [ -n "$STAGED_FILES" ]; then
        while IFS= read -r file; do
            if echo "$file" | grep -qE "(config/|tests/|node_modules)"; then
                continue
            fi

            if [ -f "$file" ]; then
                # Detecter les chemins absolus hardcodes
                local paths=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -oE "(\/var\/www\/|C:\\\\|\/home\/)" || true)
                if [ -n "$paths" ]; then
                    echo -e "${RED}❌ Chemin hardcode dans $file${NC}"
                    echo -e "${YELLOW}   Utiliser PathHelper ou AppConfig${NC}"
                    violations=$((violations + 1))
                fi
            fi
        done <<< "$STAGED_FILES"
    fi

    if [ $violations -gt 0 ]; then
        return 1

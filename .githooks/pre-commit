#!/bin/bash
###############################################################################
# @file /.githooks/pre-commit
# @description Hook pre-commit ULTRA-STRICT pour SHIELD
#
# ⚠️  ATTENTION: CE HOOK NE PEUT PAS ÊTRE BYPASSE
# ⚠️  git commit --no-verify est INTERDIT par politique projet
#
# Validations BLOQUANTES (exit 1):
# 1. Secrets/credentials hardcodes
# 2. SQL dans Controllers/Views (violation MVC)
# 3. Chemins absolus hardcodes
# 4. Protection fichiers uploads
# 5. Syntaxe PHP invalide
# 6. i18n clés manquantes
#
# Validations WARNING (informatives):
# 7. CSS non-Fibonacci
# 8. Textes hardcodes
#
# Installation:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#
# @version 2.0.0
# @date 2026-03-06
###############################################################################

set -e

# ============================================================================
# ANTI-BYPASS PROTECTION
# ============================================================================
# Si quelqu'un essaie de désactiver ce hook, on le détecte
if [ "$SHIELD_SKIP_HOOKS" = "1" ] || [ "$SKIP_HOOKS" = "1" ]; then
    echo ""
    echo "╔═══════════════════════════════════════════════════════════════════╗"
    echo "║  ⛔ TENTATIVE DE BYPASS DÉTECTÉE                                  ║"
    echo "║                                                                   ║"
    echo "║  Le bypass des hooks de pré-commit est STRICTEMENT INTERDIT.     ║"
    echo "║  Cette tentative a été loggée.                                   ║"
    echo "║                                                                   ║"
    echo "║  Si vous avez un problème légitime, corrigez le code.            ║"
    echo "╚═══════════════════════════════════════════════════════════════════╝"
    echo ""
    # Log la tentative
    echo "[$(date)] BYPASS ATTEMPT by $(git config user.email) on $(git branch --show-current)" >> .bypass_attempts.log 2>/dev/null || true
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Timer
START_TIME=$(date +%s%3N 2>/dev/null || date +%s)

echo ""
echo -e "${CYAN}╔═══════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║          SHIELD - PRE-COMMIT STRICT v1.0                          ║${NC}"
echo -e "${CYAN}╚═══════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# ============================================================================
# PROTECTION UPLOADS - Bloquer suppression de fichiers uploades
# ============================================================================
check_uploads_protection() {
    local blocked=0

    local DELETED_FILES=$(git diff --cached --name-only --diff-filter=D)
    if [ -n "$DELETED_FILES" ]; then
        while IFS= read -r file; do
            if echo "$file" | grep -qE "^storage/uploads/|^public/uploads/"; then
                if echo "$file" | grep -qE "\.(gitkeep|gitignore)$"; then
                    continue
                fi
                echo -e "${RED}❌ SUPPRESSION BLOQUEE: $file${NC}"
                echo -e "${YELLOW}   Les fichiers d'upload sont des donnees utilisateur IRREPLACABLES.${NC}"
                blocked=1
            fi
        done <<< "$DELETED_FILES"
    fi

    return $blocked
}

# Verifier la protection des uploads
if ! check_uploads_protection; then
    echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  ❌ COMMIT BLOQUE - Protection des uploads violee               ║${NC}"
    echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Protection uploads OK${NC}"

# ============================================================================
# VERIFICATION SYNTAXE PHP
# ============================================================================
check_php_syntax() {
    local PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$|\.phtml$' || true)
    local errors=0
    local use_docker=0

    # Detecter si PHP est disponible localement ou via Docker
    if ! command -v php &> /dev/null; then
        # PHP non disponible, verifier si Docker est disponible avec le container Shield
        if command -v docker &> /dev/null && docker ps 2>/dev/null | grep -q "shield-app-local"; then
            use_docker=1
            echo -e "${BLUE}📝 Verification syntaxe PHP via Docker...${NC}"
        else
            echo -e "${YELLOW}⚠️  PHP non disponible localement, Docker non accessible - syntaxe PHP non verifiee${NC}"
            return 0
        fi
    fi

    if [ -n "$PHP_FILES" ]; then
        if [ $use_docker -eq 0 ]; then
            echo -e "${BLUE}📝 Verification syntaxe PHP...${NC}"
        fi
        while IFS= read -r file; do
            if [ -f "$file" ]; then
                if [ $use_docker -eq 1 ]; then
                    # Utiliser Docker pour valider - convertir le chemin Windows en chemin Docker
                    local docker_path="//var/www/shield/$file"
                    if ! docker exec shield-app-local php -l "$docker_path" > /dev/null 2>&1; then
                        echo -e "${RED}❌ Erreur PHP: $file${NC}"
                        docker exec shield-app-local php -l "$docker_path" 2>&1 | head -3
                        errors=$((errors + 1))
                    fi
                else
                    if ! php -l "$file" > /dev/null 2>&1; then
                        echo -e "${RED}❌ Erreur PHP: $file${NC}"
                        php -l "$file" 2>&1 | head -3
                        errors=$((errors + 1))
                    fi
                fi
            fi
        done <<< "$PHP_FILES"

        if [ $errors -gt 0 ]; then
            return 1
        fi
        echo -e "${GREEN}✅ Syntaxe PHP OK${NC}"
    fi

    return 0
}

if ! check_php_syntax; then
    exit 1
fi

# ============================================================================
# DETECTION SECRETS HARDCODES
# ============================================================================
check_secrets() {
    local STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
    local found=0

    if [ -n "$STAGED_FILES" ]; then
        while IFS= read -r file; do
            # Ignorer node_modules, .env.example, et les hooks eux-memes
            if echo "$file" | grep -qE "node_modules|\.env\.example|\.githooks/"; then
                continue
            fi

            if [ -f "$file" ]; then
                # Detecter VRAIS secrets hardcodes:
                # Pattern: variable_name = 'actual_secret_value' (pas des fonctions ou des cles d'erreur)
                # Exclure: fonctions, localStorage, addEventListener, error keys, type checks, $_ENV
                local secrets=$(grep -inE "(password|secret|api_key|apikey|token|credential|private_key)\s*[=:]\s*['\"][A-Za-z0-9@#\$%\^&\*\-_+=]{12,}" "$file" 2>/dev/null | grep -vE "^\s*(#|//|/\*|\*)" | grep -vE "(password_hash|password_verify|password_too|localStorage|sessionStorage|addEventListener|getElementById|getItem|setItem|\\\$_ENV\[|\\\$this->|generateToken|input\?\.type|errors\[)" || true)
                if [ -n "$secrets" ]; then
                    echo -e "${RED}❌ SECRET DETECTE dans $file${NC}"
                    echo "$secrets" | head -3
                    found=1
                fi
            fi
        done <<< "$STAGED_FILES"
    fi

    if [ $found -eq 1 ]; then
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ SECRETS DETECTES - Utiliser .env pour les credentials         ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
        return 1
    fi

    echo -e "${GREEN}✅ Aucun secret hardcode detecte${NC}"
    return 0
}

check_secrets || exit 1

# ============================================================================
# VERIFICATION MVC - SQL dans Controllers/Views = BLOQUANT
# ============================================================================
check_mvc() {
    local STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$|\.phtml$' || true)
    local violations=0

    if [ -n "$STAGED_PHP" ]; then
        while IFS= read -r file; do
            # Controllers ne doivent pas avoir de NOUVEAU SQL (verifie seulement les lignes ajoutees)
            # Exclure: commentaires (// ou * ou #), docblocks (@method DELETE), texte descriptif
            if echo "$file" | grep -qE "Controllers/"; then
                local sql=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "(SELECT|INSERT|UPDATE|DELETE|JOIN)\s+(FROM|INTO|SET|\*|[a-z_]+)" | grep -vE "(//|/\*|\*|#|@|Soft delete|hard delete)" || true)
                if [ -n "$sql" ]; then
                    echo -e "${RED}❌ NOUVEAU SQL dans Controller: $file${NC}"
                    echo "$sql" | head -2
                    violations=$((violations + 1))
                fi
            fi

            # Views ne doivent pas avoir de NOUVEAU SQL
            if echo "$file" | grep -qE "Views/|views/"; then
                # Exclure les faux positifs HTML (<select id=) et commentaires
                local sql=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "(SELECT|INSERT|UPDATE|DELETE|JOIN)\s+(FROM|INTO|SET|\*|[a-z_]+)" | grep -vE "(//|/\*|\*|#|@|<select|selected)" || true)
                if [ -n "$sql" ]; then
                    echo -e "${RED}❌ SQL dans View: $file${NC}"
                    violations=$((violations + 1))
                fi
            fi
        done <<< "$STAGED_PHP"
    fi

    if [ $violations -gt 0 ]; then
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ VIOLATION MVC - SQL dans Controller/View                      ║${NC}"
        echo -e "${RED}║  Le SQL doit etre dans les Models uniquement                      ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
        return 1
    fi

    echo -e "${GREEN}✅ Architecture MVC OK${NC}"
    return 0
}

check_mvc || exit 1

# ============================================================================
# VERIFICATION i18n - Texte hardcode = BLOQUANT
# ============================================================================
check_i18n_hardcoded() {
    local STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(php|phtml|js)$' || true)
    local violations=0

    if [ -n "$STAGED_FILES" ]; then
        while IFS= read -r file; do
            # Ignorer les fichiers de config et lang
            if echo "$file" | grep -qE "(config/|lang/|node_modules|tests/|\.spec\.|\.test\.)"; then
                continue
            fi

            if [ -f "$file" ]; then
                # Detecter les textes francais hardcodes CRITIQUES
                # Ces patterns sont BLOQUANTS car ce sont des erreurs i18n évidentes
                local hardcoded=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -vE "(//|#|\*|console\.log)" | grep -iE "'(Erreur|Succès|Veuillez|Impossible|Chargement en cours|Connexion réussie|Déconnexion)'" | grep -vE "(__\(|_t\(|json_encode)" || true)
                if [ -n "$hardcoded" ]; then
                    echo -e "${RED}❌ Texte i18n hardcodé dans $file${NC}"
                    echo "$hardcoded" | head -2
                    violations=$((violations + 1))
                fi
            fi
        done <<< "$STAGED_FILES"
    fi

    if [ $violations -gt 0 ]; then
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ TEXTES HARDCODÉS DÉTECTÉS                                     ║${NC}"
        echo -e "${RED}║  Utiliser __('clé') et ajouter dans fr.php ET en.php              ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
        return 1
    fi

    echo -e "${GREEN}✅ i18n OK${NC}"
    return 0
}

check_i18n_hardcoded || exit 1

# ============================================================================
# VERIFICATION ACCENTS FRANÇAIS - BLOQUANT
# ============================================================================
check_french_accents() {
    local STAGED_LANG=$(git diff --cached --name-only --diff-filter=ACM | grep -E "lang/fr\.php$" || true)
    local violations=0

    if [ -n "$STAGED_LANG" ]; then
        while IFS= read -r file; do
            if [ -f "$file" ]; then
                # Detecter les mots sans accents
                local no_accents=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "'[^']*\b(mise a jour|cree|succes|resultat|termine|selectionnez|supprime|echoue|securite|parametres|telephone|deconnexion)\b[^']*'" || true)
                if [ -n "$no_accents" ]; then
                    echo -e "${RED}❌ Accents français manquants dans $file${NC}"
                    echo "$no_accents" | head -3
                    violations=$((violations + 1))
                fi
            fi
        done <<< "$STAGED_LANG"
    fi

    if [ $violations -gt 0 ]; then
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ ACCENTS FRANÇAIS MANQUANTS                                    ║${NC}"
        echo -e "${RED}║  mise a jour → mise à jour, cree → créé, succes → succès         ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
        return 1
    fi

    echo -e "${GREEN}✅ Accents français OK${NC}"
    return 0
}

check_french_accents || exit 1

# ============================================================================
# VERIFICATION CSRF/FETCH - POST sans ApiService = BLOQUANT
# ============================================================================
check_csrf_fetch() {
    local STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.js$' || true)
    local violations=0

    if [ -n "$STAGED_JS" ]; then
        while IFS= read -r file; do
            # Ignorer les services eux-mêmes et les tests
            if echo "$file" | grep -qE "(ApiService|node_modules|tests/|\.spec\.|\.test\.)"; then
                continue
            fi

            if [ -f "$file" ]; then
                # Detecter fetch avec POST/PUT/DELETE sans ApiService
                local bad_fetch=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -iE "fetch\s*\([^)]*\)\s*\.\s*then|fetch\s*\(" | grep -iE "method.*:.*['\"]?(POST|PUT|DELETE)" || true)
                if [ -n "$bad_fetch" ]; then
                    echo -e "${RED}❌ fetch() avec POST/PUT/DELETE détecté dans $file${NC}"
                    echo -e "${YELLOW}   Utiliser ApiService.post() / .put() / .delete()${NC}"
                    violations=$((violations + 1))
                fi
            fi
        done <<< "$STAGED_JS"
    fi

    if [ $violations -gt 0 ]; then
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ FETCH SANS APISERVICE - CSRF NON PROTÉGÉ                      ║${NC}"
        echo -e "${RED}║  Toujours utiliser ApiService pour POST/PUT/DELETE                ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
        return 1
    fi

    echo -e "${GREEN}✅ CSRF/ApiService OK${NC}"
    return 0
}

check_csrf_fetch || exit 1

# ============================================================================
# VERIFICATION $_POST/$_GET CAST - BLOQUANT
# ============================================================================
check_input_cast() {
    local STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$' || true)
    local violations=0

    if [ -n "$STAGED_PHP" ]; then
        while IFS= read -r file; do
            # Ignorer bootstrap et config
            if echo "$file" | grep -qE "(bootstrap|config|tests/)"; then
                continue
            fi

            if [ -f "$file" ]; then
                # Detecter $_POST['id'] ou $_GET['id'] sans cast (int)
                local no_cast=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -vE "^\+\+\+" | grep -E "\\\$_(POST|GET)\s*\[\s*['\"]id['\"]\s*\]" | grep -vE "\(int\)|\(string\)|\(float\)|\(bool\)" || true)
                if [ -n "$no_cast" ]; then
                    echo -e "${RED}❌ \$_POST/\$_GET sans cast dans $file${NC}"
                    echo "$no_cast" | head -2
                    echo -e "${YELLOW}   Utiliser (int)\$_POST['id'] ou (string)\$_POST['name']${NC}"
                    violations=$((violations + 1))
                fi
            fi
        done <<< "$STAGED_PHP"
    fi

    if [ $violations -gt 0 ]; then
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ INPUT SANS CAST DÉTECTÉ                                       ║${NC}"
        echo -e "${RED}║  TOUJOURS caster les entrées utilisateur                          ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
        return 1
    fi

    echo -e "${GREEN}✅ Input casting OK${NC}"
    return 0
}

check_input_cast || exit 1

# ============================================================================
# VERIFICATION DESIGN SYSTEM φ - Spacing Fibonacci
# ============================================================================
check_css_fibonacci() {
    local STAGED_CSS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.css$' || true)
    local violations=0

    if [ -n "$STAGED_CSS" ]; then
        while IFS= read -r file; do
            if [ -f "$file" ]; then
                # Detecter les px hardcodes non-Fibonacci (1,2,4,8,13,21,34,55,89,144)
                local bad_px=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -oE "[0-9]+px" | grep -vE "^(1|2|4|8|13|21|34|55|89|144)px$" | head -5 || true)
                if [ -n "$bad_px" ]; then
                    echo -e "${YELLOW}⚠️  Spacing non-Fibonacci dans $file: $bad_px${NC}"
                    echo -e "${YELLOW}   Utiliser: 1,2,4,8,13,21,34,55,89,144px${NC}"
                fi
            fi
        done <<< "$STAGED_CSS"
    fi

    echo -e "${GREEN}✅ Design System φ verifie${NC}"
    return 0
}

check_css_fibonacci

# ============================================================================

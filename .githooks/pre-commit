# ============================================================================
# VERIFICATION TESTS E2E OBLIGATOIRES
# ============================================================================
check_e2e_tests() {
    local STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
    local tests_to_run=""
    local run_all_tests=0

    # Determiner quels tests doivent passer en fonction des fichiers modifies
    if echo "$STAGED_FILES" | grep -qE "Controllers/AuthController|Controllers/LoginController|Views/auth/|public/api/auth\.php"; then
        tests_to_run="$tests_to_run tests/playwright/e2e/auth-complete.spec.ts"
    fi

    if echo "$STAGED_FILES" | grep -qE "Controllers/ContactController|Models/Contact|Views/contacts/|public/api/contacts\.php"; then
        tests_to_run="$tests_to_run tests/playwright/e2e/contacts-complete.spec.ts"
    fi

    if echo "$STAGED_FILES" | grep -qE "Controllers/IncidentController|Models/Incident|Views/incident/|Views/sos/|public/api/incidents\.php"; then
        tests_to_run="$tests_to_run tests/playwright/e2e/incidents-complete.spec.ts"
    fi

    if echo "$STAGED_FILES" | grep -qE "Controllers/SettingsController|Views/settings/|public/api/settings\.php"; then
        tests_to_run="$tests_to_run tests/playwright/e2e/settings-complete.spec.ts"
    fi

    if echo "$STAGED_FILES" | grep -qE "Controllers/SharingController|Models/IncidentShare|public/api/sharing\.php|public/api/track\.php|Views/track/"; then
        tests_to_run="$tests_to_run tests/playwright/e2e/sharing-complete.spec.ts"
    fi

    if echo "$STAGED_FILES" | grep -qE "Controllers/HistoryController|Views/history/|public/api/history\.php"; then
        tests_to_run="$tests_to_run tests/playwright/e2e/history-complete.spec.ts"
    fi

    # Si des fichiers critiques sont modifies, tout tester
    if echo "$STAGED_FILES" | grep -qE "bootstrap\.php|_bootstrap\.php|Middleware/|Services/Auth|config/"; then
        run_all_tests=1
    fi

    # Verifier si npx/playwright est disponible
    if ! command -v npx &> /dev/null; then
        echo -e "${YELLOW}⚠️  npx non disponible - tests E2E ignores${NC}"
        return 0
    fi

    # Si aucun fichier critique n'est modifie, pas besoin de tests
    if [ -z "$tests_to_run" ] && [ $run_all_tests -eq 0 ]; then
        echo -e "${GREEN}✅ Pas de tests E2E requis pour ces modifications${NC}"
        return 0
    fi

    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}🧪 Verification des tests E2E obligatoires...${NC}"

    # Variable d'environnement pour permettre de skip les tests en CI
    # (les tests sont executes dans une etape separee en CI)
    if [ "$SHIELD_CI" = "1" ]; then
        echo -e "${YELLOW}⚠️  Mode CI - tests E2E executes dans une etape separee${NC}"
        return 0
    fi

    cd "$PROJECT_ROOT"

    if [ $run_all_tests -eq 1 ]; then
        echo -e "${CYAN}Fichiers critiques modifies - execution de tous les tests E2E...${NC}"
        if [ -d "tests/playwright/e2e" ]; then
            npx playwright test tests/playwright/e2e/ --reporter=line 2>&1 | tail -20
            local exit_code=$?
            if [ $exit_code -ne 0 ]; then
                echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
                echo -e "${RED}║  ❌ TESTS E2E ECHOUES                                             ║${NC}"
                echo -e "${RED}║  Les tests doivent passer avant de commiter.                      ║${NC}"
                echo -e "${RED}║  Executez: npx playwright test tests/playwright/e2e/ --headed    ║${NC}"
                echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
                return 1
            fi
        fi
    else
        # Executer uniquement les tests pertinents
        for test_file in $tests_to_run; do
            if [ -f "$test_file" ]; then
                echo -e "${CYAN}Execution de $test_file...${NC}"
                npx playwright test "$test_file" --reporter=line 2>&1 | tail -10
                local exit_code=$?
                if [ $exit_code -ne 0 ]; then
                    echo -e "${RED}╔═══════════════════════════════════════════════════════════════════╗${NC}"
                    echo -e "${RED}║  ❌ TEST E2E ECHOUE: $test_file${NC}"
                    echo -e "${RED}║  Le test doit passer avant de commiter.                           ║${NC}"
                    echo -e "${RED}╚═══════════════════════════════════════════════════════════════════╝${NC}"
                    return 1
                fi
            fi
        done
    fi

    echo -e "${GREEN}✅ Tests E2E OK${NC}"
    return 0
}

# Executer la verification des tests E2E
# Note: Peut etre desactive temporairement avec SHIELD_SKIP_E2E=1
# MAIS cette variable doit etre justifiee (ex: hotfix urgent)
if [ "$SHIELD_SKIP_E2E" != "1" ]; then
    check_e2e_tests || exit 1
else
    echo -e "${YELLOW}⚠️  SHIELD_SKIP_E2E=1 - Tests E2E ignores (a utiliser avec precaution!)${NC}"
fi

# Calculer le temps ecoule
END_TIME=$(date +%s%3N 2>/dev/null || date +%s)
if [ ${#END_TIME} -gt 10 ]; then
    DURATION=$(( (END_TIME - START_TIME) ))
    echo -e "${DIM}Temps total: ${DURATION}ms${NC}"
else
    DURATION=$((END_TIME - START_TIME))
    echo -e "${DIM}Temps total: ${DURATION}s${NC}"
fi

echo ""
echo -e "${GREEN}╔═══════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║  ✅ TOUTES LES VALIDATIONS PASSENT - Commit autorise              ║${NC}"
echo -e "${GREEN}╚═══════════════════════════════════════════════════════════════════╝${NC}"
echo ""

exit 0
